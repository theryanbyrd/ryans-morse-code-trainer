# Optional — enables accounts + cross-device sync (see docs/supabase-setup.md).
# Leave unset to run guest-only on local storage.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the Supabase PUBLISHABLE key (sb_publishable_…) — the browser-safe key.
# Do NOT use the secret key (sb_secret_…); it bypasses row-level security.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
